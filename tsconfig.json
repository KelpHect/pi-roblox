{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "noEmit": true
  },
  "include": [
    "extensions/**/*.ts",
    "src/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts"
  ]
}
