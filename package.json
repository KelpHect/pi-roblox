{
  "name": "@kellhect/pi-roblox",
  "version": "0.3.0-beta.1",
  "description": "Rojo-aware Roblox Studio capabilities for the Pi coding harness",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KelpHect/pi-roblox.git"
  },
  "bugs": {
    "url": "https://github.com/KelpHect/pi-roblox/issues"
  },
  "homepage": "https://github.com/KelpHect/pi-roblox#readme",
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "extensions",
    "src",
    "skills",
    "prompts",
    "schemas",
    "docs",
    "examples",
    "scripts",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/roblox/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 test/**/*.test.ts",
    "test:e2e": "node --import tsx --test --test-concurrency=1 test/runtime-e2e.test.ts",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-concurrency=1 test/**/*.test.ts",
    "check": "npm run typecheck && npm test",
    "audit:prod": "node scripts/audit-prod.mjs",
    "verify:package": "node scripts/verify-package.mjs && npm pack --dry-run",
    "smoke:pack": "node scripts/packed-install-smoke.mjs",
    "pack": "node -e \"require('node:fs').mkdirSync('dist',{recursive:true})\" && npm pack --pack-destination dist",
    "prepack": "npm run check && node scripts/verify-package.mjs",
    "live:doctor": "node --import tsx scripts/live-doctor.ts",
    "live:acceptance": "node --import tsx scripts/live-acceptance.ts",
    "live:rojo-lifecycle": "node --import tsx scripts/live-rojo-lifecycle.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "jsonc-parser": "^3.3.1",
    "tsx": "^4.23.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.7",
    "@types/node": "^22.15.0",
    "typebox": "1.3.6",
    "typescript": "5.9.3"
  },
  "keywords": [
    "pi-package",
    "roblox",
    "rojo",
    "mcp",
    "coding-agent"
  ],
  "publishConfig": {
    "access": "public"
  }
}
